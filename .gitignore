# ──────────────────────────────────────────────
# .gitignore — Archivos que Git debe ignorar
# ──────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environment
.venv/

# Environment variables (contiene secretos)
.env

# Firebase service account key
*-firebase-adminsdk-*.json

# Database
db.sqlite3

# Static files collected
staticfiles/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
